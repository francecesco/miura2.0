# Configurazione centrale Miura Tervis
# Copiare in .env e compilare con i valori reali

# Indirizzo IP o hostname della centrale
MIURA_HOST=

# Porta TCP (default 5400)
MIURA_PORT=5400

# Codice di accesso (PIN utente)
MIURA_PIN=

# Porta HTTP del server (default 3000) — cambia anche in docker-compose.yml se modifichi
PORT=3001

# Debug protocollo (1 = log hex TX/RX su stderr)
DEBUG_PROTOCOL=0
