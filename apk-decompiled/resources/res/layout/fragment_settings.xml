<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="top"
    android:orientation="vertical"
    android:background="@android:color/white"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:gravity="top"
            android:orientation="vertical"
            android:padding="20dp"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <TextView
                android:textColor="@color/tervis_tint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/settings_items_margin_top"
                android:text="Nome impianto"
                android:layout_weight="0"/>
            <EditText
                android:enabled="false"
                android:textColor="@color/tervis_tint"
                android:id="@+id/edit_configuration_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/settings_items_margin_top"
                android:maxLines="1"
                android:maxLength="20"
                android:layout_weight="0"
                android:inputType="text"
                android:backgroundTint="@color/tervis_tint"/>
            <TextView
                android:textColor="@color/tervis_tint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/settings_items_margin_top"
                android:text="Codice utente Miura"
                android:layout_weight="0"/>
            <EditText
                android:enabled="false"
                android:textColor="@color/tervis_tint"
                android:id="@+id/edit_code"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/settings_items_margin_top"
                android:maxLines="1"
                android:maxLength="8"
                android:layout_weight="0"
                android:inputType="textPassword|number"
                android:backgroundTint="@color/tervis_tint"/>
            <TextView
                android:textColor="@color/tervis_tint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/settings_items_margin_top"
                android:text="Nome Host"
                android:layout_weight="0"/>
            <EditText
                android:enabled="false"
                android:textColor="@color/tervis_tint"
                android:id="@+id/edit_host"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/settings_items_margin_top"
                android:maxLines="1"
                android:layout_weight="0"
                android:inputType="textUri"
                android:backgroundTint="@color/tervis_tint"/>
            <TextView
                android:textColor="@color/tervis_tint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/settings_items_margin_top"
                android:text="Porta"
                android:layout_weight="0"/>
            <EditText
                android:enabled="false"
                android:textColor="@color/tervis_tint"
                android:id="@+id/edit_port"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/settings_items_margin_top"
                android:maxLines="1"
                android:maxLength="5"
                android:layout_weight="0"
                android:inputType="number"
                android:backgroundTint="@color/tervis_tint"/>
            <TextView
                android:textColor="@color/tervis_tint"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/settings_items_margin_top"
                android:text="Numero mittente SMS"
                android:layout_weight="0"/>
            <EditText
                android:enabled="false"
                android:textColor="@color/tervis_tint"
                android:id="@+id/edit_callerid"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/settings_items_margin_top"
                android:maxLines="1"
                android:layout_weight="0"
                android:inputType="phone"
                android:backgroundTint="@color/tervis_tint"/>
            <CheckBox
                android:enabled="false"
                android:textColor="@color/tervis_tint"
                android:id="@+id/check_load_texts"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/settings_items_margin_top"
                android:text="Ricarica i testi alla prossima connessione"
                android:layout_weight="0"
                android:buttonTint="@color/tervis_tint"/>
            <View
                android:textColor="@color/tervis_tint"
                android:background="@android:color/darker_gray"
                android:paddingLeft="4dp"
                android:paddingRight="4dp"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="@dimen/settings_items_margin_top"
                android:layout_marginBottom="10dp"/>
            <Button
                android:textColor="@android:color/white"
                android:id="@+id/button_delete"
                android:background="@android:color/darker_gray"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="4dp"
                android:layout_marginTop="20dp"
                android:layout_marginRight="4dp"
                android:text="Cancella configurazione"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
