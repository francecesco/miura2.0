<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center"
    android:orientation="vertical"
    android:background="@android:color/white"
    android:padding="20dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <Button
        android:id="@+id/test_connect"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Connect to Miura"
        android:layout_weight="0"/>
    <Button
        android:id="@+id/test_send"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Start service"
        android:layout_weight="0"/>
    <Button
        android:id="@+id/test_reset"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Reset Miura"
        android:layout_weight="0"/>
    <Button
        android:id="@+id/test_clock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Set clock"
        android:layout_weight="0"/>
    <Button
        android:id="@+id/test_stress"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="Stress test"
        android:layout_weight="0"/>
</LinearLayout>
