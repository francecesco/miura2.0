<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <TextView
        android:textColor="@android:color/black"
        android:gravity="center_vertical"
        android:id="@+id/text_zone_number"
        android:padding="6dp"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="60dp"
        android:text="1"
        android:layout_weight="0"/>
    <ImageView
        android:layout_gravity="center_vertical"
        android:id="@+id/image_sensor_type"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_marginRight="6dp"
        android:src="@drawable/zone_type_wired"
        android:scaleType="fitStart"
        android:layout_weight="0"/>
    <TextView
        android:textColor="@android:color/black"
        android:gravity="center_vertical"
        android:id="@+id/text_zone_name"
        android:padding="6dp"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="[nome zona sconosciuto]"
        android:layout_weight="1"/>
    <ImageView
        android:layout_gravity="center_vertical"
        android:id="@+id/image_manomissione"
        android:visibility="gone"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_marginRight="6dp"
        android:src="@drawable/zone_attack"
        android:scaleType="fitStart"
        android:layout_weight="0"/>
    <ImageView
        android:layout_gravity="center_vertical"
        android:id="@+id/image_guasto"
        android:visibility="gone"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_marginRight="6dp"
        android:src="@drawable/zone_failure"
        android:scaleType="fitStart"
        android:layout_weight="0"/>
    <ImageView
        android:layout_gravity="center_vertical"
        android:id="@+id/image_npi"
        android:visibility="gone"
        android:layout_width="30dp"
        android:layout_height="30dp"
        android:layout_marginRight="6dp"
        android:src="@drawable/door"
        android:scaleType="fitStart"
        android:layout_weight="0"/>
    <CheckBox
        android:enabled="false"
        android:id="@+id/check_zone_excluded"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_weight="0"
        android:buttonTint="@color/tervis_tint"/>
</LinearLayout>
